extends ../layout.pug
include ../mixins/_uitslag
block content 
  .ui.container 
    h1.ui.header Rituitslagen van Tour #{setting.tourjaar}
    .ui.grid(style="overflow:auto; max-height: 70vh;")
      .left.aligned.column
        .ui.list
          each etap, index in setting.tourEtappes 
            - var dat = new Intl.DateTimeFormat('nl-NL',{weekday:'short', day: 'numeric', month: 'short'}).format(new Date(etap.datum))
            if etap.nr
              .ui.segment
                h4.header.dag
                  | #{etap.nr}
                  |: #{dat}
                  | -#{etap.van} - #{etap.naar}
                  p
                form(action="/admin/rituitslag" method="POST").ui.mini.form
                  .ui.five.column.divided.grid.segment.compact.blok.hideContent
                    input(type="hidden" name="ritnr" value=etap.nr)
                    .column
                      +uitslag('ritUitsl', index+1)
                    .column
                      +uitslag('geel', index+1)
                    .column
                      +uitslag('groen', index+1)
                    .column
                      +uitslag('bol', index+1)
                    .column
                      +uitslag('wit', index+1)
                    .center.aligned.row
                      button.ui.button.positive Opslaan

  script. 
    var uitsl
    $('h4.header').click(function(){
      uitsl = $(this).parent().find('.blok')[0]
      uitsl.classList.toggle("hideContent");
    })
    
