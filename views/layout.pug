doctype
html(lang='en') 
  head
    meta(charset='utf-8')
    title Tourpool
    script(src='https://cdn.jsdelivr.net/npm/jquery@3.3.1/dist/jquery.min.js')
    script(src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.min.js") 
    link(rel='stylesheet' type='text/css' href='https://cdn.jsdelivr.net/npm/fomantic-ui@2.8.8/dist/semantic.min.css')
    script(src='https://cdn.jsdelivr.net/npm/fomantic-ui@2.8.8/dist/semantic.min.js')
    link(rel="stylesheet" href="/css/app.css")
    style.
      footer { position: absolute; bottom: 0; width: 100%; height: 30px; margin-top: 0; margin-bottom: 0; padding-top: 0; padding-bottom: 0; text-align: center}
      
  body
    .container.background
      img(src="/img/logogroot.png", alt="" style)
    .container
      .ui.yellow.inverted.large.menu
        a.header.item(href="/") 
          img.ui.tiny.spaced.image(src="/img/logo2.png", alt="Tourpool")
        .ui.dropdown.simple.link.item
          i.france.flag 
          | Tour #{setting.tourjaar}
          i.dropdown.icon
          .menu
            a.item(href="/tours")
              i.sitemap.icon 
              | Etappes
            a.item(href="/renners")
              i.tasks.icon
              | Renners
        .ui.yellow.inverted.right.menu 
          if !gebruiker || !gebruiker.username
            a.item(href="/users/register") 
              i.user.plus.icon
              | Registreer 
            a.item(href="/users/login") 
              i.user.sign.in.alternate.icon
              | Login 
          else  
            .item
              i.hand.spock.outline.icon
              | Welkom #{gebruiker.fullName}
            if gebruiker && gebruiker.isAdmin
              .ui.dropdown.simple.link.item
                i.cog.icon 
                |Admin
                i.dropdown.icon
                .menu 
                  a(href="/admin/pay").item
                    i.registered.outline.icon
                    | Formulier registreren
                  a(href="/admin/rituitslag").item
                    i.list.ol.icon
                    | Daguitslag invoeren
                  .item
                    i.print.icon
                    | Afdrukken
                    i.dropdown.icon
                    .menu 
                      a(href="#").item
                        i.wpforms.icon
                        | Formulieren
                      a(href="#").item
                        i.list.ol.icon
                        | Stand in de pool
                      a(href="#").item
                        i.columns.icon
                        | Rituitslag & klassementen
                      a(href="#").item
                        i.signal.icon
                        | Skyline
            a.item(href="/users/profiel")
              i.address.card.outline.icon
              | Je profiel
            a.item(href="/userteams")
              i.bicycle.icon
              | Jouw ploegen
            a.item(href="/users/logout")
              i.user.sign.out.alternate.icon
              | Afmelden

      .ui.grid.container.center.aligned
        .container
          .mainpage
            include partials/message
            block content 
                
  footer 
    p © #{new Date().getFullYear()} Jota Services 

script.
  $(document).ready(function(){
          $('.ui.dropdown') .dropdown();
    });