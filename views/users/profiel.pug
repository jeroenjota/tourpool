extends ../layout.pug

block content
  .ui.container
    h1.ui.header Welkom #{gebruiker.gebruikersnaam} bij Jota's Tourpool #{new Date().getFullYear()}
    - var userUrl = "/users/profiel/" + gebruiker._id
    .ui.center.aligned.grid
      .ui.raised.yellow.inverted.very.padded.text.left.aligned.segment
        form(action=userUrl method="POST").ui.left.aligned.form
          h2.ui.black.center.aligned.header Jouw gegevens
          .field  
            label(for="username") Gebruikersnaam
            input(type="text" name="username" placceholder= "Gebrukersnaam" value=gebruiker.username)
          .fields.left.aligned
            .five.wide.field 
              label(for="vNaam") Voornaam
              input(type="text" name="vNaam" placceholder= "Voornaam" value=gebruiker.vNaam)
            .three.wide.field 
              label(for="tNaam") -
              input(type="text" name="tNaam" placceholder= "tussenv" value=gebruiker.tNaam)
            .eight.wide.field 
              label(for="aNaam") Achternaam
              input(type="text" name="aNaam" placceholder= "Achternaam" value=gebruiker.aNaam)
          .field  
            label(for="email") Email
            input(type="email" name="email" placceholder= "Email" value=gebruiker.email)
          button(type="submit)").ui.right.floated.basic.big.button Opslaan
          h3.ui.black.header 
            a(href="/") Annuleren
            
                